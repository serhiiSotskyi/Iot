// ---------------------------------------------------------------------------
// Arduino lifecycle
// ---------------------------------------------------------------------------

void setup() {
  Serial.begin(115200);
  unsigned long serialWaitStart = millis();
  while (!Serial && (millis() - serialWaitStart) < 3000) {
    delay(10);
  }

  voiceReady = initVoiceModule();
  colourReady = initColourModule();
  imuReady = initImuModule();

  if (EMIT_SETUP_STATUS) {
    printSetupStatus();
  }
}

void loop() {
  switch (currentState) {
    case WAITING_FOR_VOICE:
      if (voiceDetectedStart()) {
        printJsonEvent("voice_start");
        currentState = WAITING_FOR_COLOUR;
      }
      break;

    case WAITING_FOR_COLOUR:
      if (greenDetected()) {
        Serial.println("{\"event\":\"colour_authenticated\",\"colour\":\"green\"}");
        currentState = TRACKING_MOVEMENT;
      }
      break;

    case TRACKING_MOVEMENT:
      sendMovementData();
      break;
  }
}

// ---------------------------------------------------------------------------
// State handlers
// ---------------------------------------------------------------------------

bool voiceDetectedStart() {
  if (!voiceReady) {
    return false;
  }

#if VOICE_MODULE_ENABLED
  const float startConfidence = pollStartConfidence();
  const unsigned long now = millis();

  if (startConfidence < VOICE_RELEASE_THRESHOLD) {
    voiceTriggerLatched = false;
    return false;
  }

  if (startConfidence < VOICE_START_THRESHOLD) {
    return false;
  }

  if (voiceTriggerLatched) {
    return false;
  }

  if ((now - lastVoiceTriggerMs) < VOICE_TRIGGER_COOLDOWN_MS) {
    return false;
  }

  voiceTriggerLatched = true;
  lastVoiceTriggerMs = now;
  return true;
#else
  return false;
#endif
}

bool greenDetected() {
  if (!colourReady) {
    return false;
  }

  int r = 0;
  int g = 0;
  int b = 0;
  int clearValue = 0;

  if (!readColourSample(r, g, b, clearValue)) {
    return false;
  }

  // COLOUR TEAMMATE PASTE REGION:
  // Replace this heuristic with your team's tuned/calibrated logic if needed.
  const bool clearEnough = clearValue >= GREEN_MIN_CLEAR;
  const bool greenStrongEnough = g >= GREEN_MIN_ABSOLUTE;
  const bool greenDominatesRed = g > (int)(r * GREEN_DOMINANCE_RATIO) && (g - r) >= GREEN_MIN_MARGIN;
  const bool greenDominatesBlue = g > (int)(b * GREEN_DOMINANCE_RATIO) && (g - b) >= GREEN_MIN_MARGIN;
  const bool greenNow = clearEnough && greenStrongEnough && greenDominatesRed && greenDominatesBlue;

  if (EMIT_COLOUR_DEBUG && (millis() - lastColourDebugMs) >= COLOUR_DEBUG_INTERVAL_MS) {
    printColourDebug(r, g, b, clearValue, greenNow);
    lastColourDebugMs = millis();
  }

  if (greenNow) {
    greenStreak++;
  } else {
    greenStreak = 0;
  }

  return greenStreak >= GREEN_REQUIRED_STREAK;
}

void sendMovementData() {
  if (!imuReady) {
    return;
  }

  const unsigned long now = millis();
  if ((now - lastMovementSendMs) < MOVEMENT_INTERVAL_MS) {
    return;
  }

  if (!IMU.accelerationAvailable() || !IMU.gyroscopeAvailable()) {
    return;
  }

  float ax = 0.0f;
  float ay = 0.0f;
  float az = 0.0f;
  float gx = 0.0f;
  float gy = 0.0f;
  float gz = 0.0f;

  IMU.readAcceleration(ax, ay, az);
  IMU.readGyroscope(gx, gy, gz);

  updateGravityBaseline(ax, ay, az);
  const float linearVertical = ay - gravityY;

  Serial.print("{\"event\":\"movement\",\"ax\":");
  Serial.print(ax, 3);
  Serial.print(",\"ay\":");
  Serial.print(ay, 3);
  Serial.print(",\"az\":");
  Serial.print(az, 3);
  Serial.print(",\"gx\":");
  Serial.print(gx, 3);
  Serial.print(",\"gy\":");
  Serial.print(gy, 3);
  Serial.print(",\"gz\":");
  Serial.print(gz, 3);

  if (linearVertical >= DIRECTION_THRESHOLD) {
    Serial.print(",\"direction\":\"up\"");
  } else if (linearVertical <= -DIRECTION_THRESHOLD) {
    Serial.print(",\"direction\":\"down\"");
  }

  Serial.println("}");
  lastMovementSendMs = now;
}

void printJsonEvent(const char* eventName) {
  Serial.print("{\"event\":\"");
  Serial.print(eventName);
  Serial.println("\"}");
}

// ---------------------------------------------------------------------------
// Hardware helpers
// ---------------------------------------------------------------------------

static void debugLog(const char* message) {
  if (!DEBUG_SERIAL) {
    return;
  }

  Serial.print("# ");
  Serial.println(message);
}

static bool initColourModule() {
  if (!APDS.begin()) {
    debugLog("APDS-9960 init failed.");
    return false;
  }

  return true;
}

static bool initImuModule() {
  if (!IMU.begin()) {
    debugLog("LSM9DS1 init failed.");
    return false;
  }

  return true;
}

static bool readColourSample(int &r, int &g, int &b, int &clearValue) {
  unsigned long startMs = millis();
  while (!APDS.colorAvailable()) {
    if ((millis() - startMs) > 50) {
      return false;
    }
    delay(2);
  }

  APDS.readColor(r, g, b, clearValue);
  return true;
}

static void updateGravityBaseline(float ax, float ay, float az) {
  if (!gravityInitialised) {
    gravityX = ax;
    gravityY = ay;
    gravityZ = az;
    gravityInitialised = true;
    return;
  }

  gravityX = (GRAVITY_ALPHA * gravityX) + ((1.0f - GRAVITY_ALPHA) * ax);
  gravityY = (GRAVITY_ALPHA * gravityY) + ((1.0f - GRAVITY_ALPHA) * ay);
  gravityZ = (GRAVITY_ALPHA * gravityZ) + ((1.0f - GRAVITY_ALPHA) * az);
}

static const char* stateName(SystemState state) {
  switch (state) {
    case WAITING_FOR_VOICE:
      return "WAITING_FOR_VOICE";
    case WAITING_FOR_COLOUR:
      return "WAITING_FOR_COLOUR";
    case TRACKING_MOVEMENT:
      return "TRACKING_MOVEMENT";
    default:
      return "UNKNOWN";
  }
}

static void printJsonBool(bool value) {
  Serial.print(value ? "true" : "false");
}

static void printSetupStatus() {
  Serial.print("{\"event\":\"setup_status\",\"state\":\"");
  Serial.print(stateName(currentState));
  Serial.print("\",\"voiceReady\":");
  printJsonBool(voiceReady);
  Serial.print(",\"colourReady\":");
  printJsonBool(colourReady);
  Serial.print(",\"imuReady\":");
  printJsonBool(imuReady);
  Serial.println("}");
}

static void printColourDebug(int r, int g, int b, int clearValue, bool greenNow) {
  Serial.print("{\"event\":\"colour_debug\",\"state\":\"");
  Serial.print(stateName(currentState));
  Serial.print("\",\"r\":");
  Serial.print(r);
  Serial.print(",\"g\":");
  Serial.print(g);
  Serial.print(",\"b\":");
  Serial.print(b);
  Serial.print(",\"clear\":");
  Serial.print(clearValue);
  Serial.print(",\"greenNow\":");
  printJsonBool(greenNow);
  Serial.print(",\"streak\":");
  Serial.print(greenStreak);
  Serial.print(",\"thresholds\":{\"clear\":");
  Serial.print(GREEN_MIN_CLEAR);
  Serial.print(",\"green\":");
  Serial.print(GREEN_MIN_ABSOLUTE);
  Serial.print(",\"ratio\":");
  Serial.print(GREEN_DOMINANCE_RATIO, 2);
  Serial.println("}}");
}

