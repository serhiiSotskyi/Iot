/*
 * voice_colour_motion_demo.ino
 *
 * Arduino Nano 33 BLE / Nano 33 BLE Sense demo firmware for a university
 * IoT/TinyML project. The sketch uses a simple state machine:
 *
 *   WAITING_FOR_VOICE  -> TinyML keyword "start"
 *   WAITING_FOR_COLOUR -> APDS-9960 detects green
 *   TRACKING_MOVEMENT  -> streams IMU readings as JSON over Serial
 *
 * Serial output is JSON-only for system events and movement updates so a
 * separate Python bridge can forward it to a web API.
 *
 * IMPORTANT:
 * - Set VOICE_MODULE_ENABLED to 1 after you paste in your trained
 *   Edge Impulse model header and confirm the helper code below matches
 *   your teammate's working sketch.
 * - This sketch intentionally leaves clear paste markers around the voice
 *   and colour integration points.
 */

#include <Arduino_APDS9960.h>
#include <Arduino_LSM9DS1.h>

// ---------------------------------------------------------------------------
// Config
// ---------------------------------------------------------------------------

static const bool DEBUG_SERIAL = false;
static const bool EMIT_SETUP_STATUS = true;
static const bool EMIT_VOICE_DEBUG = true;
static const bool EMIT_COLOUR_DEBUG = true;

static const float VOICE_START_THRESHOLD = 0.75f;
static const float VOICE_RELEASE_THRESHOLD = 0.35f;
static const unsigned long VOICE_TRIGGER_COOLDOWN_MS = 2000;
static const unsigned long VOICE_DEBUG_INTERVAL_MS = 500;

static const int GREEN_MIN_CLEAR = 120;
static const int GREEN_MIN_ABSOLUTE = 80;
static const int GREEN_MIN_MARGIN = 20;
static const float GREEN_DOMINANCE_RATIO = 1.20f;
static const int GREEN_REQUIRED_STREAK = 3;
static const unsigned long COLOUR_DEBUG_INTERVAL_MS = 300;

static const unsigned long MOVEMENT_INTERVAL_MS = 250;
static const float GRAVITY_ALPHA = 0.92f;
static const float DIRECTION_THRESHOLD = 0.35f;

// Set to 1 after you add the exact Edge Impulse-generated header below.
#define VOICE_MODULE_ENABLED 1

enum SystemState {
  WAITING_FOR_VOICE,
  WAITING_FOR_COLOUR,
  TRACKING_MOVEMENT
};

// ---------------------------------------------------------------------------
// Global state
// ---------------------------------------------------------------------------

static SystemState currentState = WAITING_FOR_VOICE;

static bool voiceReady = false;
static bool colourReady = false;
static bool imuReady = false;

static bool voiceTriggerLatched = false;
static unsigned long lastVoiceTriggerMs = 0;
static unsigned long lastVoiceDebugMs = 0;
static int greenStreak = 0;
static unsigned long lastColourDebugMs = 0;
static unsigned long lastMovementSendMs = 0;

static bool gravityInitialised = false;
static float gravityX = 0.0f;
static float gravityY = 0.0f;
static float gravityZ = 0.0f;

// ---------------------------------------------------------------------------
// Required function declarations
// ---------------------------------------------------------------------------

bool voiceDetectedStart();
bool greenDetected();
void sendMovementData();
void printJsonEvent(const char* eventName);

// ---------------------------------------------------------------------------
// Internal helpers
// ---------------------------------------------------------------------------

static void debugLog(const char* message);
static bool initColourModule();
static bool initImuModule();
static bool readColourSample(int &r, int &g, int &b, int &clearValue);
static void updateGravityBaseline(float ax, float ay, float az);
static const char* stateName(SystemState state);
static void printJsonBool(bool value);
static void printSetupStatus();
static void printColourDebug(int r, int g, int b, int clearValue, bool greenNow);

