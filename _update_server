#!/usr/bin/env bash
set -euo pipefail

if ! command -v git >/dev/null 2>&1; then
  echo "git is required but was not found." >&2
  exit 1
fi

if ! docker compose version >/dev/null 2>&1; then
  echo "Docker Compose is required but was not found." >&2
  exit 1
fi

if [ ! -f .env ] && [ -f .env.example ]; then
  cp .env.example .env
  echo "Created .env from .env.example. Edit BRIDGE_API_TOKEN and ADMIN_API_TOKEN before deploying."
fi

set -a
[ -f .env ] && . ./.env
set +a

missing_env=0
if [ -z "${BRIDGE_API_TOKEN:-}" ]; then
  echo "BRIDGE_API_TOKEN is required in .env." >&2
  missing_env=1
fi

if [ -z "${ADMIN_API_TOKEN:-}" ]; then
  echo "ADMIN_API_TOKEN is required in .env." >&2
  missing_env=1
fi

if [ "$missing_env" -ne 0 ]; then
  echo "Generate tokens with: openssl rand -hex 32" >&2
  exit 1
fi

git pull --ff-only
docker compose up -d --build
docker compose ps

PORT="${WEB_PORT:-3000}"
echo
echo "Dashboard: http://$(hostname -I 2>/dev/null | awk '{print $1}'):${PORT}/"
echo "If hostname detection is blank, use http://SERVER_IP:${PORT}/"
