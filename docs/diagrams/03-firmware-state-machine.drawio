<mxfile host="app.diagrams.net" type="device" version="24.0.0">
  <diagram id="fsm-01" name="Firmware state machine">
    <mxGraphModel dx="1000" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Firmware state machine" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="770" height="32" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="arduino/voice_colour_motion_demo/voice_colour_motion_demo.ino — single-task superloop with three sequential gates." style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="52" width="770" height="20" as="geometry" />
        </mxCell>

        <mxCell id="start" value="●" style="ellipse;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#000000;fontColor=#ffffff;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="400" y="100" width="30" height="30" as="geometry" />
        </mxCell>

        <mxCell id="setup" value="setup()&#10;&#10;• PDM mic init&#10;• APDS-9960 init&#10;• LSM9DS1 init&#10;• EI inferencing init&#10;&#10;Emit setup_status with&#10;voiceReady / colourReady / imuReady" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="160" width="270" height="140" as="geometry" />
        </mxCell>

        <mxCell id="fault" value="FAULT&#10;&#10;On any sensor init failure:&#10;emit debug fault log when&#10;DEBUG_SERIAL is enabled,&#10;then halt the pipeline.&#10;&#10;Bridge serial retry and silence&#10;timeout surface disconnects during&#10;manual testing." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#B85450;fontSize=11;align=left;spacingLeft=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="600" y="160" width="220" height="140" as="geometry" />
        </mxCell>

        <mxCell id="arming" value="ARM_DELAY&#10;&#10;VOICE_ARM_DELAY_MS = 4000&#10;Suppresses boot-noise false positives." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="280" y="340" width="270" height="80" as="geometry" />
        </mxCell>

        <mxCell id="voice" value="WAITING_FOR_VOICE&#10;&#10;run_classifier_continuous on PDM frames.&#10;&#10;EMIT_VOICE_DEBUG (off in production):&#10;emit voice_debug @ 2 Hz with confidence." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="460" width="270" height="120" as="geometry" />
        </mxCell>

        <mxCell id="colour" value="WAITING_FOR_COLOUR&#10;&#10;Read APDS-9960 (R, G, B, clear).&#10;Run colour classifier per-read.&#10;&#10;EMIT_COLOUR_DEBUG (off in production):&#10;emit colour_debug @ 2 Hz." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="640" width="270" height="120" as="geometry" />
        </mxCell>

        <mxCell id="motion" value="TRACKING_MOVEMENT&#10;&#10;88-sample IMU window @ 44 Hz.&#10;Convert g → m/s² before run_classifier.&#10;Emit movement event with class + confidence." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="820" width="270" height="120" as="geometry" />
        </mxCell>

        <mxCell id="end" value="◉" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=3;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="400" y="990" width="30" height="30" as="geometry" />
        </mxCell>

        <mxCell id="e_start_setup" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="start" target="setup">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_setup_fault" value="any *Ready == false" style="endArrow=classic;html=1;rounded=0;fontSize=10;fontStyle=1;strokeColor=#B85450;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="setup" target="fault">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_setup_arming" value="all sensors ready" style="endArrow=classic;html=1;rounded=0;fontSize=10;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="setup" target="arming">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_arming_voice" value="t &gt; 4000 ms" style="endArrow=classic;html=1;rounded=0;fontSize=10;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="arming" target="voice">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_voice_colour" value="confidence(start) &gt; VOICE_START_THRESHOLD&#10;(= 0.75) AND streak ≥ VOICE_REQUIRED_STREAK (= 1)&#10;⇒ emit voice_start" style="endArrow=classic;html=1;rounded=0;fontSize=10;fontStyle=1;strokeColor=#82b366;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="voice" target="colour">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_colour_motion" value="confidence(green) &gt; COLOUR_GREEN_THRESHOLD&#10;(= 0.70)&#10;⇒ emit colour_authenticated" style="endArrow=classic;html=1;rounded=0;fontSize=10;fontStyle=1;strokeColor=#82b366;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="colour" target="motion">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_voice_voice_low" value="confidence ≤ VOICE_RELEASE_THRESHOLD (= 0.35)&#10;⇒ stay armed (re-arm window)" style="endArrow=classic;html=1;rounded=0;fontSize=9;fontStyle=2;dashed=1;strokeColor=#666666;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.8;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="voice" target="voice">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="220" y="540" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="e_motion_end" value="bridge receives stopBridge=true&#10;OR session-complete POST&#10;OR power off" style="endArrow=classic;html=1;rounded=0;fontSize=10;fontStyle=1;strokeColor=#6c8ebf;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="motion" target="end">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="legend" value="&lt;b&gt;Thresholds (firmware constants)&lt;/b&gt;&lt;br&gt;VOICE_START_THRESHOLD = 0.75&lt;br&gt;VOICE_RELEASE_THRESHOLD = 0.35&lt;br&gt;VOICE_REQUIRED_STREAK = 1 (demo); production ≥ 3&lt;br&gt;VOICE_ARM_DELAY_MS = 4000&lt;br&gt;COLOUR_GREEN_THRESHOLD = 0.70&lt;br&gt;MOVEMENT_MODEL_SAMPLE_INTERVAL_MS ≈ 22.7" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;fontSize=10;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="160" width="220" height="160" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
